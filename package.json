{
  "name": "datetime-picker",
  "private": true,
  "version": "0.1.0",
  "description": "Compact button-triggered date/time picker for React. Numeric Tag/Monat/Jahr/Stunde/Minute inputs in a popup; designed for clinical-grade data entry.",
  "type": "module",
  "main": "src/DateTimePicker.tsx",
